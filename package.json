{
  "name": "agentic",
  "version": "0.1.0",
  "description": "AI agentic workflow system powered by Temporal.io and Claude",
  "scripts": {
    "worker": "tsx src/worker.ts",
    "start": "tsx src/client.ts",
    "server": "lsof -ti :${PORT:-3001} | xargs kill 2>/dev/null; tsx src/server.ts",
    "web:dev": "cd web && npm run dev",
    "build": "tsc",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@temporalio/activity": "^1.11.0",
    "@temporalio/client": "^1.11.0",
    "@temporalio/worker": "^1.11.0",
    "@temporalio/workflow": "^1.11.0",
    "@types/express": "^5.0.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.0.0",
    "@temporalio/testing": "^1.11.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "jest": "^29.0.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ]
  }
}
